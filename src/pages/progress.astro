---
import Layout from '../layouts/Layout.astro';
import ProgressTable from '../components/ProgressTable.astro';
import { getProgressEntries } from '../data/progress-sample';

const entries = await getProgressEntries();

const totalMinutes = entries.reduce((sum, e) => sum + e.durationMinutes, 0);
const avgUnderstanding =
	entries.length > 0
		? (entries.reduce((sum, e) => sum + e.understanding, 0) / entries.length).toFixed(1)
		: '—';
---

<Layout>
	<main class="container">
		<h1>学習進捗ダッシュボード</h1>

		<section class="summary">
			<div class="stat-card">
				<span class="stat-label">記録件数</span>
				<span class="stat-value">{entries.length} 件</span>
			</div>
			<div class="stat-card">
				<span class="stat-label">合計学習時間</span>
				<span class="stat-value">{totalMinutes} 分</span>
			</div>
			<div class="stat-card">
				<span class="stat-label">平均理解度</span>
				<span class="stat-value">{avgUnderstanding} / 5</span>
			</div>
		</section>

		<section class="form-section">
			<h2>学習記録入力</h2>
			<form class="entry-form">
				<div class="form-row">
					<label for="date">日付</label>
					<input type="date" id="date" name="date" />
				</div>
				<div class="form-row">
					<label for="theme">学習テーマ</label>
					<input type="text" id="theme" name="theme" placeholder="例：Astro入門" />
				</div>
				<div class="form-row">
					<label for="duration">学習時間（時間）</label>
					<input type="number" id="duration" name="duration" min="0" step="0.5" placeholder="例：1.5" />
				</div>
				<div class="form-row">
					<label for="understanding">理解度（1〜5）</label>
					<select id="understanding" name="understanding">
						<option value="">選択してください</option>
						<option value="1">1 ─ ほぼわからなかった</option>
						<option value="2">2 ─ 少し理解できた</option>
						<option value="3">3 ─ だいたい理解できた</option>
						<option value="4">4 ─ よく理解できた</option>
						<option value="5">5 ─ 完全に理解できた</option>
					</select>
				</div>
				<div class="form-row">
					<label for="nextAction">次回やること</label>
					<textarea id="nextAction" name="nextAction" rows="3" placeholder="例：ジェネリクスを復習する"></textarea>
				</div>
				<div class="form-submit">
					<button type="submit">学習を記録する</button>
				</div>
			</form>
		</section>

		<section class="table-section">
			<h2>学習記録</h2>
			{entries.length > 0 ? (
				<ProgressTable entries={entries} />
			) : (
				<p class="empty">まだ記録がありません。</p>
			)}
		</section>
	</main>
</Layout>

<style>
	.container {
		max-width: 900px;
		margin: 2rem auto;
		padding: 0 1rem;
		font-family: sans-serif;
	}
	h1 {
		font-size: 1.6rem;
		margin-bottom: 1.5rem;
	}
	h2 {
		font-size: 1.2rem;
		margin-bottom: 0.75rem;
	}
	.summary {
		display: flex;
		gap: 1rem;
		margin-bottom: 2rem;
		flex-wrap: wrap;
	}
	.stat-card {
		flex: 1;
		min-width: 140px;
		background: #f8f8f8;
		border: 1px solid #e0e0e0;
		border-radius: 8px;
		padding: 1rem 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	.stat-label {
		font-size: 0.8rem;
		color: #666;
	}
	.stat-value {
		font-size: 1.4rem;
		font-weight: bold;
	}
	.form-section {
		margin-bottom: 2.5rem;
	}
	.entry-form {
		background: #f8f8f8;
		border: 1px solid #e0e0e0;
		border-radius: 8px;
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.form-row {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}
	.form-row label {
		font-size: 0.85rem;
		font-weight: bold;
		color: #444;
	}
	.form-row input,
	.form-row select,
	.form-row textarea {
		padding: 0.5rem 0.75rem;
		border: 1px solid #ccc;
		border-radius: 6px;
		font-size: 0.95rem;
		font-family: inherit;
		background: #fff;
		width: 100%;
		box-sizing: border-box;
	}
	.form-row textarea {
		resize: vertical;
	}
	.form-submit {
		text-align: right;
	}
	.form-submit button {
		padding: 0.65rem 1.5rem;
		background: #4f46e5;
		color: #fff;
		border: none;
		border-radius: 8px;
		font-size: 1rem;
		cursor: pointer;
	}
	.form-submit button:hover {
		background: #4338ca;
	}
	.table-section {
		overflow-x: auto;
	}
	.empty {
		color: #888;
	}
</style>
