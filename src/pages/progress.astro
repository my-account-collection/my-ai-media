---
import Layout from '../layouts/Layout.astro';
import ProgressTable from '../components/ProgressTable.astro';
import { getProgressEntries } from '../data/progress-sample';

const entries = await getProgressEntries();

const totalMinutes = entries.reduce((sum, e) => sum + e.durationMinutes, 0);
const avgUnderstanding =
	entries.length > 0
		? (entries.reduce((sum, e) => sum + e.understanding, 0) / entries.length).toFixed(1)
		: '—';

// サーバー側で初期データを JSON に変換してクライアントへ渡す
const initialEntriesJson = JSON.stringify(entries);
---

<Layout>
	<main class="container">
		<h1>学習進捗ダッシュボード</h1>

		<!-- サマリーカード（JS で動的に更新する） -->
		<section class="summary">
			<div class="stat-card">
				<span class="stat-label">記録件数</span>
				<span class="stat-value" id="stat-count">{entries.length} 件</span>
			</div>
			<div class="stat-card">
				<span class="stat-label">合計学習時間</span>
				<span class="stat-value" id="stat-total">{totalMinutes} 分</span>
			</div>
			<div class="stat-card">
				<span class="stat-label">平均理解度</span>
				<span class="stat-value" id="stat-avg">{avgUnderstanding} / 5</span>
			</div>
		</section>

		<!-- 入力フォーム -->
		<section class="form-section">
			<h2>学習記録入力</h2>
			<form id="entry-form" class="entry-form" novalidate>
				<div class="form-row">
					<label for="date">日付 <span class="required">*</span></label>
					<input type="date" id="date" name="date" />
					<span class="error-msg" id="error-date"></span>
				</div>
				<div class="form-row">
					<label for="theme">学習テーマ <span class="required">*</span></label>
					<input type="text" id="theme" name="theme" placeholder="例：Astro入門" />
					<span class="error-msg" id="error-theme"></span>
				</div>
				<div class="form-row">
					<label for="duration">学習時間（時間） <span class="required">*</span></label>
					<input type="number" id="duration" name="duration" min="0.5" step="0.5" placeholder="例：1.5" />
					<span class="error-msg" id="error-duration"></span>
				</div>
				<div class="form-row">
					<label for="understanding">理解度（1〜5） <span class="required">*</span></label>
					<select id="understanding" name="understanding">
						<option value="">選択してください</option>
						<option value="1">1 ─ ほぼわからなかった</option>
						<option value="2">2 ─ 少し理解できた</option>
						<option value="3">3 ─ だいたい理解できた</option>
						<option value="4">4 ─ よく理解できた</option>
						<option value="5">5 ─ 完全に理解できた</option>
					</select>
					<span class="error-msg" id="error-understanding"></span>
				</div>
				<div class="form-row">
					<label for="nextAction">次回やること <span class="required">*</span></label>
					<textarea id="nextAction" name="nextAction" rows="3" placeholder="例：ジェネリクスを復習する"></textarea>
					<span class="error-msg" id="error-nextAction"></span>
				</div>
				<div class="form-submit">
					<button type="submit">学習を記録する</button>
				</div>
			</form>
		</section>

		<!-- 学習記録テーブル（tbody を JS で操作する） -->
		<section class="table-section">
			<h2>学習記録</h2>
			<table class="progress-table" id="progress-table">
				<thead>
					<tr>
						<th>日付</th>
						<th>学習テーマ</th>
						<th>学習時間</th>
						<th>理解度</th>
						<th>次回やること</th>
					</tr>
				</thead>
				<tbody id="progress-tbody">
					{entries.map((entry) => (
						<tr>
							<td>{entry.date}</td>
							<td>{entry.theme}</td>
							<td>{entry.durationMinutes}分</td>
							<td>{'★'.repeat(entry.understanding)}{'☆'.repeat(5 - entry.understanding)}</td>
							<td>{entry.nextAction}</td>
						</tr>
					))}
				</tbody>
			</table>
		</section>
	</main>
</Layout>

<!-- クライアントサイドのロジック -->
<script define:vars={{ initialEntriesJson }}>
	// --- 初期データの読み込み ---
	// Astro サーバー側で作った JSON をここで受け取る
	// 将来 AWS に切り替えるときは initialEntriesJson の代わりに fetch() で取得するだけでよい
	const entries = JSON.parse(initialEntriesJson);
	let nextId = entries.length + 1;

	// --- DOM 要素の参照 ---
	const form = document.getElementById('entry-form');
	const tbody = document.getElementById('progress-tbody');
	const statCount = document.getElementById('stat-count');
	const statTotal = document.getElementById('stat-total');
	const statAvg = document.getElementById('stat-avg');

	// --- バリデーション ---
	function validate(data) {
		const errors = {};
		if (!data.date) errors.date = '日付を入力してください';
		if (!data.theme.trim()) errors.theme = '学習テーマを入力してください';
		if (!data.duration || data.duration <= 0) errors.duration = '学習時間を入力してください';
		if (!data.understanding) errors.understanding = '理解度を選択してください';
		if (!data.nextAction.trim()) errors.nextAction = '次回やることを入力してください';
		return errors;
	}

	function showErrors(errors) {
		['date', 'theme', 'duration', 'understanding', 'nextAction'].forEach((field) => {
			const el = document.getElementById(`error-${field}`);
			const input = document.getElementById(field);
			if (errors[field]) {
				el.textContent = errors[field];
				input.classList.add('input-error');
			} else {
				el.textContent = '';
				input.classList.remove('input-error');
			}
		});
	}

	// --- テーブル行の生成 ---
	function createRow(entry) {
		const stars = '★'.repeat(entry.understanding) + '☆'.repeat(5 - entry.understanding);
		const tr = document.createElement('tr');
		tr.innerHTML = `
			<td>${entry.date}</td>
			<td>${entry.theme}</td>
			<td>${entry.durationMinutes}分</td>
			<td>${stars}</td>
			<td>${entry.nextAction}</td>
		`;
		return tr;
	}

	// --- サマリーの再計算 ---
	function updateSummary() {
		const count = entries.length;
		const totalMinutes = entries.reduce((sum, e) => sum + e.durationMinutes, 0);
		const avg = count > 0
			? (entries.reduce((sum, e) => sum + e.understanding, 0) / count).toFixed(1)
			: '—';
		statCount.textContent = `${count} 件`;
		statTotal.textContent = `${totalMinutes} 分`;
		statAvg.textContent = `${avg} / 5`;
	}

	// --- フォーム送信 ---
	form.addEventListener('submit', (e) => {
		e.preventDefault();

		const data = {
			date: form.date.value,
			theme: form.theme.value,
			duration: parseFloat(form.duration.value),
			understanding: parseInt(form.understanding.value, 10),
			nextAction: form.nextAction.value,
		};

		const errors = validate(data);
		showErrors(errors);
		if (Object.keys(errors).length > 0) return;

		// 新しいエントリを作成（学習時間は分に変換して保持）
		const newEntry = {
			id: String(nextId++),
			date: data.date,
			theme: data.theme,
			durationMinutes: Math.round(data.duration * 60),
			understanding: data.understanding,
			nextAction: data.nextAction,
		};

		// ブラウザメモリの配列へ追加
		// 将来はここを fetch('/api/progress', { method: 'POST', body: JSON.stringify(newEntry) }) に差し替える
		entries.push(newEntry);

		// テーブルの末尾に行を追加
		tbody.appendChild(createRow(newEntry));

		// サマリーを更新
		updateSummary();

		// フォームをリセット
		form.reset();
		showErrors({});
	});
</script>

<style>
	.container {
		max-width: 900px;
		margin: 2rem auto;
		padding: 0 1rem;
		font-family: sans-serif;
	}
	h1 {
		font-size: 1.6rem;
		margin-bottom: 1.5rem;
	}
	h2 {
		font-size: 1.2rem;
		margin-bottom: 0.75rem;
	}
	.summary {
		display: flex;
		gap: 1rem;
		margin-bottom: 2rem;
		flex-wrap: wrap;
	}
	.stat-card {
		flex: 1;
		min-width: 140px;
		background: #f8f8f8;
		border: 1px solid #e0e0e0;
		border-radius: 8px;
		padding: 1rem 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	.stat-label {
		font-size: 0.8rem;
		color: #666;
	}
	.stat-value {
		font-size: 1.4rem;
		font-weight: bold;
	}
	.form-section {
		margin-bottom: 2.5rem;
	}
	.entry-form {
		background: #f8f8f8;
		border: 1px solid #e0e0e0;
		border-radius: 8px;
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.form-row {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}
	.form-row label {
		font-size: 0.85rem;
		font-weight: bold;
		color: #444;
	}
	.required {
		color: #e53e3e;
	}
	.form-row input,
	.form-row select,
	.form-row textarea {
		padding: 0.5rem 0.75rem;
		border: 1px solid #ccc;
		border-radius: 6px;
		font-size: 0.95rem;
		font-family: inherit;
		background: #fff;
		width: 100%;
		box-sizing: border-box;
	}
	.form-row textarea {
		resize: vertical;
	}
	.input-error {
		border-color: #e53e3e !important;
	}
	.error-msg {
		font-size: 0.8rem;
		color: #e53e3e;
		min-height: 1rem;
	}
	.form-submit {
		text-align: right;
	}
	.form-submit button {
		padding: 0.65rem 1.5rem;
		background: #4f46e5;
		color: #fff;
		border: none;
		border-radius: 8px;
		font-size: 1rem;
		cursor: pointer;
	}
	.form-submit button:hover {
		background: #4338ca;
	}
	.table-section {
		overflow-x: auto;
	}
	.progress-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.95rem;
	}
	.progress-table th,
	.progress-table td {
		border: 1px solid #ddd;
		padding: 0.6rem 0.8rem;
		text-align: left;
		vertical-align: top;
	}
	.progress-table th {
		background-color: #f5f5f5;
	}
	.progress-table tr:nth-child(even) {
		background-color: #fafafa;
	}
</style>
