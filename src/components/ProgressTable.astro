---
import type { ProgressEntry } from '../lib/progress/types';

interface Props {
	entries: ProgressEntry[];
}

const { entries } = Astro.props;

const understandingLabel = (level: ProgressEntry['understanding']) =>
	'★'.repeat(level) + '☆'.repeat(5 - level);
---

<table class="progress-table">
	<thead>
		<tr>
			<th>日付</th>
			<th>学習テーマ</th>
			<th>学習時間</th>
			<th>理解度</th>
			<th>次回やること</th>
		</tr>
	</thead>
	<tbody>
		{entries.map((entry) => (
			<tr>
				<td>{entry.date}</td>
				<td>{entry.theme}</td>
				<td>{entry.durationMinutes}分</td>
				<td>{understandingLabel(entry.understanding)}</td>
				<td>{entry.nextAction}</td>
			</tr>
		))}
	</tbody>
</table>

<style>
	.progress-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.95rem;
	}
	.progress-table th,
	.progress-table td {
		border: 1px solid #ddd;
		padding: 0.6rem 0.8rem;
		text-align: left;
		vertical-align: top;
	}
	.progress-table th {
		background-color: #f5f5f5;
	}
	.progress-table tr:nth-child(even) {
		background-color: #fafafa;
	}
</style>
